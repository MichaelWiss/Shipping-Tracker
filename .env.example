# Shipping-Tracker environment variables.
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored; this file is committed as documentation.

# --- Supabase ---------------------------------------------------------------
# Project URL, e.g. https://abcdefghij.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Anon (public) key — safe to expose to the browser, RLS-gated
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — SERVER ONLY. Bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- External data sources --------------------------------------------------
# AISStream.io WebSocket API key (vessel AIS positions)
AISSTREAM_API_KEY=
# U.S. EIA Open Data API key (daily fuel/bunker price proxy series)
EIA_API_KEY=

# --- Internal ---------------------------------------------------------------
# Shared secret guarding /api/*-sync and /api/cii-nightly cron endpoints.
# Vercel Cron sends this in the Authorization header; routes must verify it.
CRON_SECRET=
